# Maintainer: Elias Farah <234085+eliasfarah@users.noreply.github.com>
pkgname=playsync
pkgver=0.4.0
pkgrel=1
pkgdesc="Backup automatico de saves da Steam para a nuvem (daemon systemd --user + CLI/TUI)"
arch=('x86_64')
url="https://github.com/eliasfarah/playsync"
license=('MIT')
depends=('gcc-libs' 'systemd')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/eliasfarah/playsync/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')
# O `lto` padrao do makepkg injeta -flto=auto em CFLAGS/CXXFLAGS/LDFLAGS. A
# aws-lc-sys (dependencia transitiva do reqwest/rustls) compila C com esse
# CFLAGS; o resultado sao objetos GCC-LTO que o link final do Rust (que nao
# participa da mesma sessao de LTO do gcc) nao consegue resolver — dá
# "undefined symbol: aws_lc_0_42_0_*" mesmo com o simbolo presente no .a
# gerado. Confirmado isolando so essa flag fora do makepkg tambem. O LTO do
# proprio Rust (`[profile.release] lto = true` no Cargo.toml) continua ativo
# normalmente — isso so desliga o LTO que o makepkg tentaria aplicar no C.
options=('!lto')

prepare() {
    cd "$pkgname-$pkgver"
    cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
    cd "$pkgname-$pkgver"
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release --workspace
}

check() {
    cd "$pkgname-$pkgver"
    cargo test --frozen --workspace
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 target/release/playsync  "$pkgdir/usr/bin/playsync"
    install -Dm755 target/release/playsyncd "$pkgdir/usr/bin/playsyncd"
    install -Dm644 packaging/systemd/playsyncd.service \
        "$pkgdir/usr/lib/systemd/user/playsyncd.service"
}
